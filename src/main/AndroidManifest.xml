<?xml version="1.0" encoding="utf-8"?>
<manifest xmlns:android="http://schemas.android.com/apk/res/android">
    <uses-permission android:name="android.permission.INTERNET" />

    <!--
      Library-level Network Security Config: cleartext traffic is disabled.
      Host apps can still override, but the SDK's own network calls use
      ApiClient, which independently refuses non-https URLs.
    -->
    <application
        android:networkSecurityConfig="@xml/sendora_network_security_config"
        tools:targetApi="24"
        xmlns:tools="http://schemas.android.com/tools" />
</manifest>
